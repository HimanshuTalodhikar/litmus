APP_NAME=product-copilot
ENVIRONMENT=dev
LOG_LEVEL=INFO

AWS_REGION=us-east-1

# CodeMax LLM (OpenAI-compatible)
CODERMAX_API_KEY=sk-cm-your-api-key
CODERMAX_BASE_URL=https://api.codemax.pro
CODERMAX_MODEL=claude-sonnet-4-6

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# RDS PostgreSQL
DB_HOST=product-copilot-db.xxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=productcopilot
DB_USER=copilot_user
DB_PASSWORD=your-db-password

# ElastiCache Redis
REDIS_HOST=product-copilot-redis.xxxxxx.apse1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_USE_SSL=true
